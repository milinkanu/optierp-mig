# Copy to .env for local development (never commit real secrets)

# Required — at least 32 chars
SECRET_KEY=local-dev-secret-key-change-in-production-0001

# App role (non-owner => RLS enforced) and owner role (Alembic)
DATABASE_URL=postgresql+asyncpg://erp_app:erp_app_dev_pw@localhost:5432/erp
MIGRATIONS_DATABASE_URL=postgresql+asyncpg://erp_owner:erp_owner_dev_pw@localhost:5432/erp

REDIS_URL=redis://localhost:6379/0
ALLOWED_ORIGINS=http://localhost:5173
ENVIRONMENT=development
REFRESH_COOKIE_SECURE=false
SCHEDULER_ENABLED=true

# SMTP — dev uses the Mailhog catcher (docker-compose). View sent mail at http://localhost:8025
# For production swap in a transactional provider (SES/SendGrid/Postmark) + set SPF/DKIM on your domain.
SMTP_HOST=localhost
SMTP_PORT=587
SMTP_USER=
SMTP_PASSWORD=
SMTP_FROM=noreply@example.com
SMTP_TLS=true
